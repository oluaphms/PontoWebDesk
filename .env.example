# URL do app em desenvolvimento (porta fixa 3010). Recomendado para auth/redirect.
# VITE_APP_URL=http://localhost:3010

# Supabase (obrigatório)
# Copie para .env.local e preencha. Obtenha em: https://supabase.com/dashboard → Project → Settings → API
# Se VITE_SUPABASE_URL estiver errada, o app gera timeout de conexão.
VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ========== APIs serverless (Vercel / produção) ==========
# Chave para APIs: POST /api/rep/punch, /api/rep/sync, /api/punches, etc.
# Gere uma chave forte (ex: openssl rand -hex 32) e use a mesma no header: Authorization: Bearer <API_KEY>
API_KEY=

# Opcional: chave só para relógios REP (POST /api/rep/punch). Se não definir, usa API_KEY.
# REP_API_KEY=

# Opcional: segredo para cron (sincronização REP a cada 5 min). No Vercel, defina CRON_SECRET e o cron envia esse valor no Authorization.
CRON_SECRET=
# Em produção (Vercel): Settings → Environment Variables → CRON_SECRET = mesmo valor que você usar no cron
