# ============================================
# SmartPonto - Variáveis de ambiente (exemplo)
# ============================================
# Copie para .env.local e preencha. Nunca commite .env.local.
# ============================================

# Supabase (obrigatório)
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anon

# Convites por email (opcional – Edge Function ou API que use Supabase Admin inviteUserByEmail)
# VITE_INVITE_API_URL=https://seu-projeto.supabase.co/functions/v1/invite-user

# Perfis de teste (apenas desenvolvimento):
# Crie usuários no Supabase Auth e na tabela public.users.
# Ex.: admin@smartponto.com (role: admin), desenvolvedor@smartponto.com (role: employee).
# Consulte CONFIGURAR_SUPABASE.md para detalhes.
