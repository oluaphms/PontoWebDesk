# ============================================
# CHRONOS PREMIUM - Environment Variables
# ============================================
# 
# INSTRUÇÕES:
# 1. Copie este arquivo para .env.local
# 2. Preencha as variáveis com suas credenciais
# 3. NUNCA commite o arquivo .env.local no Git
#
# ============================================

# Google Gemini API Key (para insights de IA)
# Obtenha em: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here
# Opcional — padrão: gemini-2.0-flash-exp
# Modelos compatíveis com API v1beta: gemini-2.0-flash-exp, gemini-1.5-flash, gemini-1.5-pro
# NOTA: gemini-2.0-flash (sem -exp) pode retornar erro 400 na v1beta
# VITE_GEMINI_MODEL=gemini-2.0-flash-exp

# Firebase Configuration
# Obtenha em: https://console.firebase.google.com/
# Vá em Project Settings > General > Your apps > Web app
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Firebase Emulator (opcional - para desenvolvimento local)
# VITE_USE_FIREBASE_EMULATOR=false
# VITE_FIREBASE_EMULATOR_HOST=localhost
# VITE_FIREBASE_EMULATOR_PORT=9099

# URL do app (recomendado em dev para auth/redirect na porta fixa 3010)
# VITE_APP_URL=http://localhost:3010

# Supabase (obrigatório para o app)
VITE_SUPABASE_URL=https://aigegesxwrmgktmkbers.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImFpZ2VnZXN4d3JtZ2t0bWtiZXJzIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NjkxOTA4NzYsImV4cCI6MjA4NDc2Njg3Nn0.Xisa8x9160iIQufdvyRjacm0oWkDufF9WNUjT8ke5oo

# Sentry (opcional - error tracking)
# VITE_SENTRY_DSN=https://xxx@yyy.ingest.sentry.io/zzz

# Environment
VITE_APP_ENV=development
# VITE_APP_ENV=production

# ========== APIs serverless (obrigatório para /api/rep/* e cron) ==========
# Gere uma chave forte: no terminal: openssl rand -hex 32
# Use a mesma chave em API_KEY e (opcionalmente) em CRON_SECRET no Vercel
API_KEY=
CRON_SECRET=
# Opcional: chave só para relógios REP
# REP_API_KEY=

# ========== AGENTE LOCAL (clock-sync-agent) ==========
# ⚠️  SEGURANÇA: SUPABASE_SERVICE_ROLE_KEY NUNCA deve ir para o frontend!
#     Esta chave tem acesso total ao banco (bypass RLS). Use apenas no agente/backend.
#
# Modo API intermediária (RECOMENDADO): validação centralizada no servidor
# - Agente envia para /api/punch com CLOCK_AGENT_API_KEY
# - API valida device_id, rate limit, e insere com SERVICE_ROLE (backend)
# - Agente NUNCA tem acesso direto ao banco
CLOCK_AGENT_API_URL=http://localhost:3000
CLOCK_AGENT_API_KEY=use_mesmo_valor_de_API_KEY_acima

# Modo direto (LEGACY - use apenas se não puder usar API intermediária)
# - Agente conecta direto ao Supabase via SERVICE_ROLE
# - Menos seguro, mas útil em ambientes isolados/restrictos
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_URL=${VITE_SUPABASE_URL}

# Intervalo de sync do agente (ms). Default: 10000 (10s)
# CLOCK_AGENT_INTERVAL_MS=10000

# SQLite local: onde salvar a fila offline. Default: agent/data/pending.db
# CLOCK_AGENT_SQLITE_PATH=agent/data/pending.db

# Tabelas do agente (defaults costumam funcionar)
# SUPABASE_TIME_LOGS_TABLE=clock_event_logs
# SUPABASE_DEVICES_TABLE=devices
# SUPABASE_SYNC_LOGS_TABLE=clock_sync_logs

# Desativar promoção espelho (útil em dev)
# CLOCK_SYNC_SKIP_ESPELHO=0
