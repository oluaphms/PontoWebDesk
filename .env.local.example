# ============================================
# CHRONOS PREMIUM - Environment Variables
# ============================================
# 
# INSTRUÇÕES:
# 1. Copie este arquivo para .env.local
# 2. Preencha as variáveis com suas credenciais
# 3. NUNCA commite o arquivo .env.local no Git
#
# ============================================

# Google Gemini API Key (para insights de IA)
# Obtenha em: https://makersuite.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Configuration
# Obtenha em: https://console.firebase.google.com/
# Vá em Project Settings > General > Your apps > Web app
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Firebase Emulator (opcional - para desenvolvimento local)
# VITE_USE_FIREBASE_EMULATOR=false
# VITE_FIREBASE_EMULATOR_HOST=localhost
# VITE_FIREBASE_EMULATOR_PORT=9099

# Environment
VITE_APP_ENV=development
# VITE_APP_ENV=production
